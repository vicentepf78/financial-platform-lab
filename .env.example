# Financial Platform Lab — variáveis de ambiente (template)
# Copie para .env.local e preencha com valores reais. NUNCA commite .env.local.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_platform
DB_USER=financial
DB_PASSWORD=financial

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Backend ---
SERVER_PORT=8080

# --- JWT / Spring Security (security.jwt.*) ---
# SECURITY_JWT_ENABLED → security.jwt.enabled (default false — rollout gradual)
# JWT_SECRET → security.jwt.secret (obrigatório em produção com enabled=true; ≥256 bits para HS256)
# JWT_EXPIRATION_SECONDS → security.jwt.expiration-seconds (default 3600)
# JWT_OPERATOR_PASSWORD → security.jwt.users.operator.password (default operator)
# JWT_ADMIN_PASSWORD → security.jwt.users.admin.password (default admin)
SECURITY_JWT_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_SECONDS=3600
JWT_OPERATOR_PASSWORD=operator
JWT_ADMIN_PASSWORD=admin

# --- Mercado Pago (sandbox / teste) ---
# Painel: https://www.mercadopago.com.br/developers/panel/app
# Apps (App ID do painel — via MCP):
#   POC-FINANCIAL-PLATAFORM-LAB          → 3292380386767339 (recomendada)
#   POC-FINANCIAL-PLATAFORM-LAB-LEGACY   → 1509789861543837
# API: Orders (POST /v1/orders) — NÃO usar /v1/payments (legacy)

# Backend — NUNCA expor no frontend
MERCADO_PAGO_APPLICATION_ID=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com

# URL pública para webhooks (tunnel HTTPS em dev, ex.: ngrok)
MERCADO_PAGO_WEBHOOK_URL=

# Usuário de teste comprador (sandbox)
MERCADO_PAGO_TEST_BUYER_USER=
MERCADO_PAGO_TEST_BUYER_PASSWORD=
MERCADO_PAGO_TEST_BUYER_EMAIL=

# Frontend — copie também para frontend/.env.local com prefixo VITE_
# VITE_MERCADO_PAGO_PUBLIC_KEY=
